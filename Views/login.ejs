<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <title>Cadastro - CodeSpark</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/main.css">

  <style>
    body {
      background-color: black;
      color: white;
    }

    .card-form {
      background: linear-gradient(135deg,#111,#000);
      border-radius:20px;
      box-shadow:0px 0px 20px rgba(255,0,0,0.4);
    }

    .btn-main {
      background:#ff2c2c;
      color:white;
      border:none;
    }

    .btn-main:hover{
      background:#ff0000;
    }
  </style>
</head>

<body>

 <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-black">
    <div class="container">

      <a class="navbar-brand" href="#">
        <h1>CodeSpark</h1>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="menu">
        <ul class="navbar-nav ms-auto">

          <li class="nav-item">
            <a class="nav-link" href="#">Sobre nós</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="#">Serviços</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="#">Contato</a>
          </li>

        </ul>
      </div>

    </div>
  </nav>

<!-- FORM -->
<div class="container mt-5">

  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card-form p-4">

        <h3 class="text-center mb-4">Criar Conta</h3>

        <form method="POST" action="/register">

          <input class="form-control mb-3" type="text" name="nome" placeholder="Nome completo" required>

          <input class="form-control mb-3" type="number" name="idade" placeholder="Idade">

          <select class="form-control mb-3" name="sexo">
            <option>Sexo</option>
            <option>Masculino</option>
            <option>Feminino</option>
            <option>Outro</option>
          </select>

          <input class="form-control mb-3" type="email" name="email" placeholder="E-mail" required>

          <input class="form-control mb-3" type="password" name="senha" placeholder="Senha" required>

          <input class="form-control mb-3" type="text" name="cpf" placeholder="CPF">

          <input class="form-control mb-3" type="text" name="nascimento" placeholder="Data de nascimento">

          <hr>

          <h5 class="text-center">Pagamento</h5>

          <input class="form-control mb-3" type="text" name="cartao" placeholder="Número do cartão">

          <div class="row">
            <div class="col">
              <input class="form-control mb-3" type="text" name="validade" placeholder="Validade (MM/AA)">
            </div>

            <div class="col">
              <input class="form-control mb-3" type="text" name="cvv" placeholder="CVV">
            </div>
          </div>

          <button class="btn btn-main w-100">Cadastrar</button>

        </form>

        <!-- MENSAGEM -->
        <% if (message && message.length > 0) { %>
          <p class="text-center mt-3 text-success"><%= message %></p>
        <% } %>

      <a href="/login-exclusivo" class="btn btn-light w-100" >Já tenho conta</a>

      </div>

    </div>
  </div>

</div>

</body>
</html>