<!DOCTYPE html>
<html lang="pt-br">

<head>
<meta charset="UTF-8">
<title>Login Exclusivo</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:black;
    color:white;
}

.login-box{
    background:#111;
    border-radius:20px;
    box-shadow:0px 0px 20px rgba(255,0,0,0.5);
}
</style>

</head>

<body>

<div class="container d-flex justify-content-center align-items-center" style="height:100vh;">

    <div class="login-box p-5 text-center" style="width:400px;">

        <h2>🔐 Login Premium</h2>

        <form action="/log" method="POST">

            <input type="email" name="email" class="form-control mb-3" placeholder="E-mail" required>

            <input type="password" name="senha" class="form-control mb-3" placeholder="Senha" required>

            <button class="btn btn-danger w-100">Entrar</button>

        </form>

        <p class="text-danger mt-3"><%= message %></p>

        <a href="/" class="text-light">Voltar</a>

    </div>

</div>

</body>
</html>